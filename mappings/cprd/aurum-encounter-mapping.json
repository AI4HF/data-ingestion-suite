{
  "id": "aurum-encounter-mapping",
  "url": "https://ai4hf.eu/fhir/mappings/cprd/aurum-encounter-mapping",
  "name": "aurum-encounter-mapping",
  "title": "aurum-encounter-mapping",
  "isDraft": false,
  "source": [
    {
      "alias": "consultation",
      "url": "https://ai4hf.eu/fhir/schemas/cprd/Aurum-consultation",
      "joinOn": [
        "patid"
      ]
    },
    {
      "alias": "patient",
      "url": "https://ai4hf.eu/fhir/schemas/cprd/Aurum-patient",
      "joinOn": [
        "patid"
      ]
    }
  ],
  "context": {},
  "variable": [
    {
      "name": "encounterDate",
      "language": "text/fhirpath",
      "expression": "consdate.utl:toFhirDateTime('dd/MM/yyyy')"
    },
    {
      "name": "isBetweenPatientRegDates",
      "language": "text/fhirpath",
      "expression": "%patient.regstartdate.utl:toFhirDateTime('dd/MM/yyyy') <= %encounterDate and iif(%patient.regenddate.exists(),%patient.regenddate.utl:toFhirDateTime('dd/MM/yyyy') >= %encounterDate,true)"
    }
  ],
  "mapping": [
    {
      "precondition": {
        "name": "medicationGroupExists",
        "language": "text/fhirpath",
        "expression": "%isBetweenPatientRegDates"
      },
      "expression": {
        "name": "encounter",
        "language": "application/fhir-template+json",
        "value": {
          "id": "{{mpp:getHashedId('Encounter', consid)}}",
          "meta": {
            "profile": [
              "https://datatools4heart.eu/fhir/StructureDefinition/HFR-Encounter"
            ]
          },
          "resourceType": "Encounter",
          "class": [
            {
              "coding": [
                {
                  "system": "http://terminology.hl7.org/CodeSystem/v3-ActCode",
                  "code": "AMB",
                  "display": "ambulatory"
                }
              ]
            }
          ],
          "subject": "{{mpp:createFhirReferenceWithHashedId('Patient', patid)}}",
          "actualPeriod": {
            "start": "{{%encounterDate}}",
            "end": "{{%encounterDate}}"
          },
          "identifier": [
            {
              "value": "{{ consid }}"
            }
          ],
          "status": "completed"
        }
      }
    }
  ]
}