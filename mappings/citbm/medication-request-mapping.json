{
  "id": "medication-request-mapping",
  "url": "https://ai4hf.eu/fhir/mappings/citbm/medication-request-mapping",
  "name": "medication-request-mapping",
  "title": "Medication Request Mapping from CITBM's Prescription Data.",
  "isDraft": false,
  "source": [
    {
      "alias": "prescription",
      "url": "https://ai4hf.eu/fhir/schemas/citbm/Prescription",
      "joinOn": []
    }
  ],
  "context": {
    "prescriptionFrequencyContext": {
      "category": "concept-map",
      "url": "$CONTEXT_REPO/citbm/prescription-frequency.csv"
    }
  },
  "variable": [
    {
      "name": "frequencyCount",
      "language": "text/fhirpath",
      "expression": "mpp:getConcept(%prescriptionFrequencyContext, frequency , 'target_count').toDecimal()"
    }
  ],
  "mapping": [
    {
      "expression": {
        "name": "medicationRequest",
        "language": "application/fhir-template+json",
        "value": {
          "id": "{{mpp:getHashedId('MedicationRequest', subject & encounter & startDate & ATCcode)}}",
          "meta": {
            "profile": [
              "https://datatools4heart.eu/fhir/StructureDefinition/HFR-MedicationRequest"
            ]
          },
          "resourceType": "MedicationRequest",
          "medication": {
            "concept": {
              "coding": [
                {
                  "system": "http://www.whocc.no/atc",
                  "code": "{{ATCcode}}",
                  "display": "{{name}}",
                  "@sliceName": "atcCode"
                }
              ]
            }
          },
          "subject": "{{mpp:createFhirReferenceWithHashedId('Patient', subject)}}",
          "encounter": "{{mpp:createFhirReferenceWithHashedId('Encounter', subject & encounter.lower())}}",
          "status": "completed",
          "intent": "order",
          "effectiveDosePeriod": {
            "start": "{{startDate.utl:toFhirDate('dd/MM/yyyy')}}"
          },
          "dosageInstruction": [
            {
              "timing": {
                "repeat": {
                  "boundsDuration": {
                    "system": "http://unitsofmeasure.org",
                    "code": "d",
                    "value": "{{dosageValue / %frequencyCount}}",
                    "unit": "days"
                  },
                  "frequency": "{{%frequencyCount}}",
                  "period": 1,
                  "periodUnit": "d"
                }
              },
              "doseAndRate": [
                {
                  "doseQuantity": {
                    "system": "http://unitsofmeasure.org",
                    "code": "tbl",
                    "value": 1,
                    "unit": "tablet"
                  }
                }
              ]
            }
          ]
        }
      }
    }
  ]
}