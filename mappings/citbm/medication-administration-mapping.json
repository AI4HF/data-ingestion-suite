{
  "id": "medication-administration-mapping",
  "url": "https://ai4hf.eu/fhir/mappings/citbm/medication-administration-mapping",
  "name": "medication-administration-mapping",
  "title": "The medication administration",
  "isDraft": false,
  "source": [
    {
      "alias": "medication",
      "url": "https://ai4hf.eu/fhir/schemas/citbm/Medication",
      "joinOn": []
    }
  ],
  "context": {
    "medicationContext": {
      "category": "concept-map",
      "url": "$CONTEXT_REPO/citbm/medication-atc-dosage.csv"
    }
  },
  "variable": [
    {
      "name": "medication",
      "language": "text/fhirpath",
      "expression": "mpp:getConcept(%medicationContext, name)"
    }
  ],
  "mapping": [
    {
      "description": "Medication administration",
      "expression": {
        "name": "medication",
        "language": "application/fhir-template+json",
        "value": {
          "id": "{{mpp:getHashedId('MedicationAdministration', identifier)}}",
          "meta": {
            "profile": [
              "https://datatools4heart.eu/fhir/StructureDefinition/HFR-MedicationAdministration"
            ]
          },
          "resourceType": "MedicationAdministration",
          "medication": {
            "concept": {
              "coding": [
                {
                  "system": "http://www.whocc.no/atc",
                  "code": "{{%medication.target_code}}",
                  "display": "{{%medication.target_display}}",
                  "@sliceName": "atcCode"
                }
              ]
            }
          },
          "subject": "{{mpp:createFhirReferenceWithHashedId('Patient', subject)}}",
          "encounter": "{{mpp:createFhirReferenceWithHashedId('Encounter', subject & encounter.lower())}}",
          "occurenceDateTime": "{{startDate.utl:toFhirDateTime('dd/MM/yyyy')}}",
          "dosage": {
            "dose": {
              "value": "{{iif(%medication.dosage.exists(),%medication.dosage.toDecimal() * dosageValue,dosageValue)}}",
              "unit": "{{iif(%medication.dosage_unit.exists(),%medication.dosage_unit,dosageUnit)}}"
            }
          },
          "status": "completed"
        }
      }
    }
  ]
}